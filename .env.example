# ============================================================
# Application Configuration
# ============================================================

APP_NAME=Digital Twin of Andrew Ng
APP_VERSION=1.0.0
APP_ENV=development

HOST=127.0.0.1
PORT=8000

DEBUG=True
LOG_LEVEL=INFO


# ============================================================
# Database
# ============================================================

DATABASE_URL=sqlite:///backend/database/database.db


# ============================================================
# Storage Paths
# ============================================================

CHROMA_DB_PATH=vector_db
MEMORY_STORE_PATH=memory_store
SCIENTIST_DATA_PATH=scientist_data


# ============================================================
# Gemini API Keys
# ============================================================

# Add Gemini API keys separated by commas
#
# Example:
# GEMINI_API_KEYS=AIza_xxxxx,AQ_xxxxx

GEMINI_API_KEYS=YOUR_GEMINI_API_KEY_1,YOUR_GEMINI_API_KEY_2


# ============================================================
# Gemini Models
# ============================================================

PRIMARY_MODEL=gemini-3.5-flash

FALLBACK_MODEL=gemini-2.5-pro

FAST_MODEL=gemini-3.1-flash-lite

EMBEDDING_MODEL=gemini-embedding-2


# ============================================================
# LLM Reliability
# ============================================================

LLM_MAX_RETRIES=3

LLM_RETRY_DELAY=2

KEY_COOLDOWN_SECONDS=60


# ============================================================
# Key Scheduler
# ============================================================

KEY_ROTATION_STRATEGY=round_robin

ENABLE_MODEL_FALLBACK=True

ENABLE_KEY_ROTATION=True


# ============================================================
# Memory
# ============================================================

ENABLE_MEMORY=True

MAX_MEMORY_MESSAGES=50


# ============================================================
# RAG
# ============================================================

ENABLE_RAG=True

VECTOR_DATABASE=chromadb

TOP_K_RESULTS=5


# ============================================================
# Development
# ============================================================

ENVIRONMENT=local