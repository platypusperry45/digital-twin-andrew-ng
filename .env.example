# Core Application Settings
APP_NAME="Digital Twin of Andrew Ng"
ENV="production"
LOG_LEVEL="INFO"
HOST="0.0.0.0"
PORT=8000

# Gemini AI Engine (Gemini 2.5 Flash as mandated)
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048

# RAG & Vector Store Configuration
VECTORSTORE_DIR="./backend/data/vectorstore"
KNOWLEDGE_REGISTRY_PATH="./backend/data/knowledge/registry.json"
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.65

# Memory Configuration
MEMORY_DIR="./backend/data/memory"
SHORT_TERM_MEMORY_MAX_MESSAGES=10
LONG_TERM_MEMORY_TOP_K=3

# Personality Settings
DEFAULT_PERSONA="andrew_ng"
TIMELINE_AWARENESS_ENABLED=true